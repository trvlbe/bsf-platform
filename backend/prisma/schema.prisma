generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CampaignStatus {
  DRAFT
  GENERATING
  GENERATED
  PUBLISHING
  ACTIVE
  COMPLETE
}

enum Platform {
  TIKTOK
  INSTAGRAM
  YOUTUBE
  FACEBOOK
}

enum VideoStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model User {
  id           String     @id @default(cuid())
  googleId     String     @unique
  email        String     @unique
  name         String
  avatarUrl    String?
  accessToken  String?
  refreshToken String?
  anthropicApiKey        String?
  bufferAccessToken      String?
  bufferProfileTiktok    String?
  bufferProfileInstagram String?
  bufferProfileYoutube   String?
  bufferProfileFacebook  String?
  higgsfieldApiKey       String?
  campaigns    Campaign[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Campaign {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id])
  slug             String
  title            String
  artist           String
  label            String
  releaseDate      DateTime
  musicUrl           String?
  assetsFolderUrl  String?
  creativeBrief      String?
  contentOrientation String  @default("VERTICAL")
  contentDuration    String  @default("SHORT_FORM")
  contentResolution  String  @default("1080p")
  platforms        Platform[]
  brandTone        String
  brandIdentity    String
  lyricsDocUrl     String?
  lyricsMarkdown   String?
  preReleaseDays   Int            @default(14)
  postReleaseDays  Int            @default(14)
  videoEnabled     Boolean        @default(false)
  videoStyle       String?
  videoSourceImage String?
  status           CampaignStatus @default(DRAFT)
  arc              CampaignArc?
  posts            Post[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([userId, slug])
}

model CampaignArc {
  id           String   @id @default(cuid())
  campaignId   String   @unique
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  preTheme     String
  dropDayTheme String
  postTheme    String
  motifs       String[]
  rawJson      String
  createdAt    DateTime @default(now())
}

model Post {
  id          String       @id @default(cuid())
  campaignId  String
  campaign    Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  platform    Platform
  caption     String
  hashtags    String[]
  lyricSource String
  assetNote   String
  scheduledAt DateTime
  dayOffset   Int
  bufferId    String?
  videoJobId  String?
  videoStatus VideoStatus?
  videoUrl    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([campaignId, dayOffset])
}
